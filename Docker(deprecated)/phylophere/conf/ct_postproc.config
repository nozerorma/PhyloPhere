// CT Post-Processing Workflow Configuration
// Handles cluster filtering and characterization of disambiguation master results

params {
    // =====================================================
    // General Parameters for CT Post-Processing
    // =====================================================

    // Input/Output
    discovery_input = discovery_input ?: ""  // Expected integrated source: ct_disambiguation/caas_convergence_master.csv
    background_input = background_input ?: ""  // Required: path to background file(s) or directory (if not from CT_DISCOVERY)
    
    // Processing mode
    caas_postproc_mode = caas_postproc_mode ?: "filter"  // "exploratory" or "filter"
    
    // Exploratory mode parameters (parameter sweep)
    minlen_values = minlen_values ?: "2,3,4,10"
    maxcaas_values = maxcaas_values ?: "0.6,0.7,0.8"
    
    // Filter mode parameters (single run)
    filter_minlen = filter_minlen ?: 2
    filter_maxcaas = filter_maxcaas ?: 0.6
    
    // Gene-level filtering options
    gene_filter_mode = gene_filter_mode ?: "both"  // "none", "extreme", "dubious", "both"
    extreme_threshold = extreme_threshold ?: 0.99  // Top 1% = 0.99 quantile
    iqr_multiplier = iqr_multiplier ?: 3.0  // 3×IQR threshold for dubious genes
    
    // Visualization options
    generate_reports = generate_reports ?: true
    generate_manhattan = generate_manhattan ?: true
    manhattan_min_density = manhattan_min_density ?: 0.008  // Minimum density for Manhattan plot display
    
    // Processing options
    verbose = verbose ?: false
    mrca_posterior_threshold = mrca_posterior_threshold ?: 0.9  // Remove rows when any mrca_*_posterior is below this threshold
        
    // =====================================================
    // CT Signification Analysis Parameters
    // =====================================================
    
    // Bootstrap input (required)
    bootstrap_input = bootstrap_input                   ?: null     // Path to directory containing .boot files from permutation tests

    // Significance thresholds
    alpha_threshold = alpha_threshold                   ?: 0.05     // Alpha level for both hypergeometric and permutation tests

    // Output options
    export_gene_lists = export_gene_lists               ?: true     // Export gene lists for enrichment analysis
    export_meta_ct = export_meta_ct                     ?: true     // Export meta-CT metadata
    
    // Gene list export formats
    gene_list_format = gene_list_format                 ?: "txt"  // Format: txt (one gene per line)
    

    // =====================================================
    // Process-Specific Settings
    // =====================================================
    
    // Signification report process
    signification_report {
        cpus = 4
        memory = '8.GB'
        time = '2.h'
    }
}

process {
    withName: 'CT_FILTER' {
        cpus = 1
        memory = { check_max( 500.MB, 'memory' ) }
        time = { check_max( 2.h, 'time' ) }
    }
    
    withName: 'CT_FILTER_SUMMARY' {
        cpus = 1
        memory = { check_max( 100.MB, 'memory' ) }
        time = { check_max( 10.m, 'time' ) }
    }
    
    withName: 'CT_POSTPROC_REPORT' {
        cpus = 2
        memory = { check_max( 4.GB, 'memory' ) }
        time = { check_max( 4.h, 'time' ) }
    }
}
