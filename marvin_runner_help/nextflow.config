/*
 * ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
 * Configuration file for setting up global parameters, process-specific resource requirements,
 * and execution profiles. This ensures optimal resource allocation and flexibility across
 * different compute environments.
 * This file can be left essentially untouched by the user, as most parameters are set in conf/common.config and other config files. 
 * ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
 */

// Redirect logs to stable log dir: $ export NXF_LOG_FILE="log/nextflow.log" (must be set in console before running the script)

// Global default params, used in configs
params {
    // Use singularity flipper. DO NOT MODIFY, it initializes the parameter.
    use_singularity             = use_singularity           ?: false
    use_apptainer               = use_apptainer             ?: false
}

// Specify that apptainer/singularity should be used and where the cache dir will be for the images.
// The singularity directive is used in favour of the apptainer one, because currently the apptainer
// variant will pull in (and convert) docker images, instead of using pre-built singularity ones.
// See https://nf-co.re/docs/usage/installation#pipeline-software
// and https://nf-co.re/tools#how-the-singularity-image-downloads-work
// See https://www.nextflow.io/docs/latest/config.html#scope-singularity

// Apptainer added for last Nextflow versions. Singularity is Legacy and will be removed.

// process.container = 'docker://miralnso/phylophere:latest'

profiles {
    // Container related profiles
    singularity {
        params {
            use_singularity         =  true
        }
        // Use pre-pulled local SIF -- see apptainer profile comment.
        process.container = "$baseDir/apptainer/miralnso-phylophere-latest.img"
        singularity.enabled         = true
        singularity.autoMounts      = true
        // Cache on external drive — /home is ~95% full and /tmp (tmpfs 7.5 GB)
        // is too small to unpack the image layers during a cold pull.
        singularity.cacheDir        = "/media/miguel/adfbf391-5867-414b-8af7-bceb102e6e92/apptainer_cache"
        // ociAutoPull MUST be false: Nextflow 25.x inline pull-then-exec fails with
        // "Failed to create container process: Operation not permitted" under
        // Ubuntu 24.04 AppArmor userns restrictions.  Pre-pull via run script instead.
        singularity.ociAutoPull     = false
    }
    apptainer {
        params {
            use_apptainer           =  true
        }
        // Use pre-pulled local SIF to avoid the Nextflow 25.x inline pull-then-exec
        // failure (ERROR: Failed to create container process: Operation not permitted)
        // on a cold cache. The SIF must exist at $baseDir/apptainer/miralnso-phylophere-latest.img;
        // run scripts include a pre-pull guard that creates it automatically.
        process.container = "$baseDir/apptainer/miralnso-phylophere-latest.img"
        apptainer.enabled         = true
        apptainer.autoMounts      = true
        // Cache on external drive — /home is ~95% full and /tmp (tmpfs 7.5 GB)
        // is too small to unpack the image layers during a cold pull.
        apptainer.cacheDir        = "/media/miguel/adfbf391-5867-414b-8af7-bceb102e6e92/apptainer_cache"
        // ociAutoPull MUST be false: Nextflow 25.x inline pull-then-exec fails with
        // "Failed to create container process: Operation not permitted" under
        // Ubuntu 24.04 AppArmor userns restrictions.  Pre-pull via run script instead.
        apptainer.ociAutoPull     = false
    }
    
    // Run related profiles
    // SLURM cluster auto-selection. Honestly, I don't really know how to make this work.
    // Just go for the local profile even if you are on a cluster. It'll make a single job, sadly in the same 
    // node, but spreading the workload per threads.
    slurm {
        params {
            config_profile_description = 'Marvin Cluster @UPF-CSIC'
            config_profile_contact     = 'miguel.ramon@upf.edu'
            config_profile_url         = 'https://www.ibe.upf-csic.es'
            max_memory                 = 64.GB
            max_cpus                   = 64
            max_time                   = 960.h
        }
        process {
            executor = 'slurm'
        }
    }

    // Ad‑hoc local run. This works perfectly. If running in cluster, just adjust the resources.
    local {
        params {
            config_profile_description = 'Custom ad-hoc local run'
            config_profile_contact     = 'miguel.ramon@upf.edu'
            config_profile_url         = 'https://www.ibe.upf-csic.es'
            max_memory                 = 32.GB
            max_cpus                   = 16
            max_time                   = 5.day
        }
        process {
            executor = 'local'
        }
    }
}

// Export these variables to prevent local Python/R libraries from conflicting with those in the container

env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
}

process.shell = ['/bin/bash', '-euo', 'pipefail']

manifest {
    name            = 'PhyloPhere'
    author          = """Miguel Ramon Alonso"""
    homePage        = 'https://github.com/nozerorma/PhyloPhere'
    description     = """Nexflow pipeline for running phylogenetic analyses"""
    mainScript      = 'main.nf'
    nextflowVersion = '!>=21.04.0'
    version         = '2.0'
    doi             = ''
}

// Functions to fetch the available CPUs and memory of the current execution node.
// Allows dynamic assignment based on SLURM environment or a fixed default.

def parse_slurm_cpu_value(value, int fallback) {
    if (value == null) {
        return fallback
    }

    def text = value.toString().trim()
    if (!text) {
        return fallback
    }

    if (text ==~ /^\d+$/) {
        return text.toInteger()
    }

    def matcher = text =~ /^(\d+)(?:\(x\d+\))?$/
    if (matcher.matches()) {
        return matcher[0][1].toInteger()
    }

    return fallback
}

def get_allocated_cpus(int node_max_cpu) {
    return parse_slurm_cpu_value(
        System.getenv('SLURM_CPUS_PER_TASK') ?: System.getenv('SLURM_JOB_CPUS_PER_NODE'),
        node_max_cpu
    )
}

def get_allocated_mem(int node_max_mem) {
    def memPerCpu = System.getenv('SLURM_MEM_PER_CPU')
    def cpusPerTask = parse_slurm_cpu_value(
        System.getenv('SLURM_CPUS_PER_TASK') ?: System.getenv('SLURM_JOB_CPUS_PER_NODE'),
        0
    )
    if (memPerCpu && cpusPerTask) {
        // Use integer division to compute total memory in GB
        node_max_mem = memPerCpu.toInteger().intdiv(1000) * cpusPerTask
    }
    return "${node_max_mem}.GB"
}

// Helper to cap resource requests
// Compares requested obj against max defined in params

def check_max(obj, type) {
    try {
        switch(type) {
            case 'memory':
                return (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                       ? params.max_memory as nextflow.util.MemoryUnit
                       : obj
            case 'time':
                return (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                       ? params.max_time as nextflow.util.Duration
                       : obj
            case 'cpus':
                return Math.min(obj, params.max_cpus as int)
            default:
                return obj
        }
    } catch(all) {
        println "### WARNING ### Invalid params.max_${type}='${params["max_${type}"]}' – using default $obj"
        return obj
    }
}

// Executor configuration: local and slurm
executor {
    $local {
        // Dynamically set total cores and memory
        cpus     = get_allocated_cpus(16)
        memory   = get_allocated_mem(64)
    }
    $slurm {
        submitRateLimit  = '30/1min'
        queueSize        = 30
        exitReadTimeout  = 7.day
    }
}

// Load shared configurations
includeConfig 'conf/resources.config'
includeConfig 'conf/common.config'
includeConfig 'conf/ct.config'
includeConfig 'conf/rerconverge.config'
includeConfig 'conf/ora.config'
includeConfig 'conf/ct_signification.config'
includeConfig 'conf/ct_disambiguation.config'
includeConfig 'conf/ct_postproc.config'
includeConfig 'conf/ct_accumulation.config'
includeConfig 'conf/fade.config'
includeConfig 'conf/molerate.config'
