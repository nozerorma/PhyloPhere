#!/usr/bin/env nextflow

/*
 * Resource configuration: defaults + process label requirements
 */

params {
    // Defaults used when no profile overrides are active
    max_memory = 64.GB
    max_cpus   = 64
    max_time   = 5.day
}

process {
    // ── Generic labels ─────────────────────────────────────────────────────
    withLabel:process_discovery {
        cpus   = { 8 }
        memory = { 2.GB }
        time   = { 1.h }
        maxForks   = 8 // Number of parallel jobs to run. Should be total assigned cores % cores per job
    }
    withLabel:process_resample {
        cpus   = { 12 }
        memory = { 4.GB }
        time   = { 2.h }
    }
    withLabel:process_boot {
        cpus   = { 8 }
        memory = { 16.GB }
        time   = { 72.h }
        maxForks   = 8 // Number of parallel jobs to run. Should be total assigned cores % cores per job
    }
    withLabel:process_low {
        cpus   = { 1 }
        memory = { 500.MB }
        time   = { 2.h }
    }
    withLabel:process_medium {
        cpus   = { 2 }
        memory = { 4.GB }
        time   = { 4.h }
    }
    withLabel:process_long_compute {
        cpus   = { 1 }
        memory = { 4.GB * task.attempt }
        time   = { 12.h * task.attempt }
    }
    withLabel:process_reporting {
        cpus   = { 4 }
        memory = { 2.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withLabel:process_reporting_phenotype {
        cpus   = { 10 }
        memory = { 6.GB * task.attempt }
        time   = { 2.h  * task.attempt }
    }
    withLabel:process_reporting_dataset {
        cpus   = { 4 }
        memory = { 4.GB * task.attempt }
        time   = { 2.h  * task.attempt }
    }
    withLabel:process_contrast_selection {
        cpus   = { 8 }
        memory = { 4.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withLabel:error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }

    withName: 'DISCOVERY_BATCHED' {
        cpus   = { params.ct_discovery_batch_workers as int }
        memory = { 100.MB }
        time   = { 1.h }
    }

    withName: 'BOOTSTRAP_BATCHED' {
        cpus   = { 2 * (params.ct_bootstrap_batch_workers as int) }
        memory = { 2.GB }
        time   = { 72.h }
    }

    // ── CT Post-Processing ────────────────────────────────────────────────
    withName: 'CT_FILTER' {
        cpus   = { 2 }
        memory = { 1.GB }
        time   = { 2.h }
    }
    withName: 'CT_FILTER_SUMMARY' {
        cpus   = { 2 }
        memory = { 1.GB }
        time   = { 10.m }
    }
    withName: 'CT_POSTPROC_REPORT' {
        cpus   = { 12 }
        memory = { 6.GB }
        time   = { 4.h }
    }

    // ── CT Signification ──────────────────────────────────────────────────
    withName: 'CAAS_SIGNIFICATION_REPORT' {
        cpus   = { 12 }
        memory = { 4.GB }
        time   = { 2.h }
    }

    // ── CT Accumulation ───────────────────────────────────────────────────
    withName: 'CT_ACCUMULATION_AGGREGATE' {
        cpus   = { 16 }
        memory = { 8.GB  * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withName: 'CT_ACCUMULATION_RANDOMIZE' {
        cpus   = { 12 }
        memory = { 24.GB * task.attempt }
        time   = { 12.h  * task.attempt }
    }

    // ── ORA / STRING ──────────────────────────────────────────────────────
    withName: 'ORA_GENERAL_REPORT' {
        cpus   = { 8 }
        memory = { 8.GB }
        time   = { 6.h }
    }
    withName: 'STRING_GENERAL_REPORT' {
        cpus   = { 8 }
        memory = { 8.GB }
        time   = { 6.h }
    }

    // ── Shared alignment prep (SELECTION_PREP) ────────────────────────────
    withName: 'PREP_ALIGNMENTS' {
        cpus   = { 1 }
        memory = { 500.MB * task.attempt }
        time   = { 30.m  * task.attempt }
    }
    withName: 'PREP_ALIGNMENTS_BATCHED' {
        cpus   = { params.selection_prep_batch_workers as int }
        memory = { 2.GB * task.attempt }
        time   = { 1.h  * task.attempt }
    }

    // ── FADE ──────────────────────────────────────────────────────────────
    withName: 'PHYLIP_TO_FASTA' {
        cpus   = { 1 }
        memory = { 2.GB * task.attempt }
        time   = { 30.m * task.attempt }
    }
    withName: 'ANNOTATE_TREE_FG' {
        cpus   = { 8 }
        memory = { 4.GB * task.attempt }
        time   = { 30.m * task.attempt }
    }
    withName: 'ANNOTATE_TREE_FG_BATCHED' {
        cpus          = { params.fade_batch_workers as int }
        memory        = { (params.fade_batch_workers as int) * 1.GB * task.attempt }
        time          = { 1.h  * task.attempt }
        errorStrategy = { task.exitStatus in [140, 137, 143] ? 'retry' : 'terminate' }
        maxRetries    = 3
    }
    withName: 'COLLECT_GENE_SETS' {
        cpus   = { 2 }
        memory = { 4.GB * task.attempt }
        time   = { 30.m * task.attempt }
    }
    withName: 'FADE_RUN' {
        cpus   = { 12 }
        memory = { 4.GB  * task.attempt }
        time   = { 12.h  * task.attempt }
    }
    withName: 'FADE_REPORT' {
        cpus   = { 8 }
        memory = { 8.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }

    // ── MoleRate ──────────────────────────────────────────────────────────
    withName: 'EXTRACT_FG_BRANCHES' {
        cpus   = { 8 }
        memory = { 1.GB * task.attempt }
        time   = { 30.m * task.attempt }
    }
    withName: 'MOLERATE_RUN' {
        cpus   = { 12 }
        memory = { 4.GB  * task.attempt }
        time   = { 12.h  * task.attempt }
    }
    withName: 'MOLERATE_REPORT' {
        cpus   = { 8 }
        memory = { 8.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }

    // ── VEP characterization ────────────────────────────────────────────────
    withLabel: 'process_vep' {
        cpus   = { 4 }
        memory = { 8.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withName: 'PROT2COORD' {
        cpus   = { 4 }
        memory = { 8.GB * task.attempt }
        time   = { 8.h  * task.attempt }
    }
    withName: 'PROT2AA' {
        cpus   = { 4 }
        memory = { 8.GB * task.attempt }
        time   = { 8.h  * task.attempt }
    }
    withName: 'PRIMATEAI_MAP' {
        // Streams the full PrimateAI-3D database (~2 GB gz); needs enough memory
        // to hold the in-memory position lookup table.
        cpus   = { 2 }
        memory = { 16.GB * task.attempt }
        time   = { 8.h  * task.attempt }
    }

    // ── RERconverge ─────────────────────────────────────────────────────────
    // RER_TREES reads all gene trees into R at once; needs significantly more
    // memory than the generic process_reporting label provides (8 GB × attempt).
    withName: 'RER_TREES' {
        cpus   = { 4 }
        memory = { 32.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    // RER_MATRIX loads the same gene-tree forest as RER_TREES and then calls
    // getAllResiduals() — needs at least as much memory as RER_TREES.
    withName: 'RER_MATRIX' {
        cpus   = { 4 }
        memory = { 32.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    // RER analysis as such loads the same gene-tree forest as RER_TREES and then calls
    // getAllResiduals() — needs at least as much memory as RER_TREES.
    withName: 'RER_CONT' {
        cpus   = { 4 }
        memory = { 32.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withName: 'RER_BIN' {
        cpus   = { 4 }
        memory = { 32.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }

    // ── Scoring ─────────────────────────────────────────────────────────────
    withName: 'SCORING_COMPUTE' {
        cpus   = { 4 }
        memory = { 8.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withName: 'SCORING_REPORT' {
        cpus   = { 8 }
        memory = { 8.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
}
