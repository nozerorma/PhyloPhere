/*
 * CT_ACCUMULATION configuration
 *
 * Parameters controlling the CT Accumulation subworkflow, which tests
 * for significant accumulation of CAAS at the gene level via permutation.
 */

params {
    // Standalone inputs (used when running without the integrated pipeline).
    // When running integrated (ct_postproc = true),
    // the filtered_discovery.tsv output of ct_postproc is used automatically.
    accumulation_caas_input         = accumulation_caas_input         ?: ""   // filtered_discovery.tsv (postproc/gene_filtering)
    accumulation_background_input   = accumulation_background_input   ?: ""   // cleaned_background_main.txt (or dir)

    // Randomization settings
    accumulation_n_randomizations   = accumulation_n_randomizations   ?: 1000000
    accumulation_randomization_type = accumulation_randomization_type ?: "naive"  // naive | matched
    accumulation_workers            = accumulation_workers            ?: null    // null → auto (all CPUs)
    accumulation_seed               = accumulation_seed               ?: 1998    // null → no fixed seed

    // FDR / significance threshold
    accumulation_fdr                = accumulation_fdr                ?: 0.1

    // Python log level
    accumulation_log_level          = accumulation_log_level          ?: "INFO"
}

// Resource configuration for CT Accumulation processes is in conf/resources.config
