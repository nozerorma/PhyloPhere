/*
 * CT disambiguation configuration
 */

params {
    ct_disambiguation = ct_disambiguation ?: false

    ct_disambig_root = ct_disambig_root ?: "${baseDir}/to_integrate/6.CAAS_disambiguation"
    ct_disambig_script = ct_disambig_script ?: "${baseDir}/subworkflows/CT_DISAMBIGUATION/local/disambiguation_main.py"

    // Shared/common inputs
    ct_disambig_caas_metadata = ct_disambig_caas_metadata ?: ""

    ct_disambig_asr_mode = ct_disambig_asr_mode ?: "precomputed"
    ct_disambig_asr_model = ct_disambig_asr_model ?: "lg"
    ct_disambig_asr_cache_dir = ct_disambig_asr_cache_dir ?: null
    ct_disambig_convergence_mode = ct_disambig_convergence_mode ?: "focal_clade"
    ct_disambig_posterior_threshold = ct_disambig_posterior_threshold ?: 0.7

    // If null, process will derive from task.cpus
    ct_disambig_threads = ct_disambig_threads ?: null
    ct_disambig_workers = ct_disambig_workers ?: null
    ct_disambig_max_tasks_per_child = ct_disambig_max_tasks_per_child ?: 50

    ct_disambig_include_non_significant = ct_disambig_include_non_significant ?: true
    ct_disambig_run_diagnostics = ct_disambig_run_diagnostics ?: true
    ct_disambig_skip_gene_lists = ct_disambig_skip_gene_lists ?: false
    ct_disambig_verbose = ct_disambig_verbose ?: true
    ct_disambig_use_all_mrca_filter = ct_disambig_use_all_mrca_filter ?: true
}

