/*
##
#  CAAS Signification Configuration
#
#  Configuration for CAAS signification analysis workflow
#  Defines parameters for significance testing, bootstrap integration,
#  and output formatting for gene lists and meta-CAAS data.
#
*/

params {
    // =====================================================
    // CAAS Signification Analysis Parameters
    // =====================================================
    
    // Bootstrap input (required)
    bootstrap_input = null  // Path to directory containing .boot files from permutation tests
    
    // Output directory
    signification_outdir = "${params.outdir}/caas_signification"
    
    // Significance thresholds
    alpha_threshold = 0.05  // Alpha level for both hypergeometric and permutation tests
    
    // CAAP mode (inherited from discovery file or explicitly set)
    caap_mode = false  // Set to true for group-aware analysis
    
    // Output options
    export_gene_lists = true     // Export gene lists for enrichment analysis
    export_meta_caas = true      // Export meta-CAAS metadata
    export_commonalities = false // Export cross-contrast commonality tables (disabled for single-contrast)
    
    // Gene list export formats
    gene_list_format = "txt"  // Format: txt (one gene per line)
    
    // =====================================================
    // Process-Specific Settings
    // =====================================================
    
    // Signification report process
    signification_report {
        cpus = 4
        memory = '8.GB'
        time = '2.h'
    }
}
