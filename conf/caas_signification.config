/*
##
#  CAAS Signification Configuration
#
#  Configuration for CAAS signification analysis workflow
#  Defines parameters for significance testing, bootstrap integration,
#  and output formatting for gene lists and meta-CAAS data.
#
*/

params {
    // =====================================================
    // CAAS Signification Analysis Parameters
    // =====================================================
    
    // Bootstrap input (required)
    bootstrap_input = bootstrap_input                   ?: null     // Path to directory containing .boot files from permutation tests

    // Significance thresholds
    alpha_threshold = alpha_threshold                   ?: 0.05     // Alpha level for both hypergeometric and permutation tests

    // Output options
    export_gene_lists = export_gene_lists               ?: true     // Export gene lists for enrichment analysis
    export_meta_caas = export_meta_caas                 ?: true     // Export meta-CAAS metadata
    
    // Gene list export formats
    gene_list_format = gene_list_format                 ?: "txt"  // Format: txt (one gene per line)
    
    // =====================================================
    // Process-Specific Settings
    // =====================================================
    
    // Signification report process
    signification_report {
        cpus = 4
        memory = '8.GB'
        time = '2.h'
    }
}
