#!/usr/bin/env nextflow

/*
 * SCORING module configuration
 *
 * Composite CAAS scoring at position-level and gene-level.
 * Integrates outputs from CT_POSTPROC, FADE, RERConverge,
 * and CT_ACCUMULATION into a unified scoring framework.
 */

params {
    // ── Master toggle ──────────────────────────────────────────────────────
    scoring                     = false

    // ── ORA on scoring gene lists ──────────────────────────────────────────
    scoring_ora                 = true
    scoring_stress              = false
    scoring_stress_top_n        = 25
    scoring_stress_rank_metric  = "spearman"

    // ── Thresholds for ORA gene list extraction ────────────────────────────
    scoring_position_top_pct    = 0.10       // Top 10% positions by CAAS_score
    scoring_position_top5_pct   = 0.05       // Top 5%  positions by CAAS_score
    scoring_position_top1_pct   = 0.01       // Top 1%  positions by CAAS_score
    scoring_gene_top_pct        = 0.10       // Top 10% genes by each gene-level score
    scoring_gene_top5_pct       = 0.05       // Top 5%  genes by each gene-level score
    scoring_gene_top1_pct       = 0.01       // Top 1%  genes by each gene-level score

    // ── Standalone mode fallbacks ──────────────────────────────────────────
    // When scoring runs without upstream pipeline channels, provide paths
    // directly.  Leave empty ("") to skip that component.
    scoring_postproc_input      = ""         // filtered_discovery.tsv
    scoring_fade_summary_top    = ""         // fade_summary_top.tsv
    scoring_fade_summary_bottom = ""         // fade_summary_bottom.tsv
    scoring_rer_input           = ""         // rerconverge_summary_{trait}.tsv
    scoring_accum_dir               = ""     // directory with accumulation_{scheme}_aggregated_results.csv
    scoring_molerate_summary_top    = ""     // molerate_summary_top.tsv
    scoring_molerate_summary_bottom = ""     // molerate_summary_bottom.tsv
    scoring_vep_transvar            = ""     // transvar_annotations.tsv
    scoring_vep_primateai           = ""     // primateai_scores.tsv
    scoring_background_input        = ""     // cleaned_background_main.txt
}
