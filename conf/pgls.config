/*
 * Site-PGLS configuration
 * Phylogenetic GLS association on CT post-processed CAAS sites
 */
params {
    // Enable the site-level PGLS workflow.
    pgls                   = pgls                   ?: false

    // Standalone CAAS input file.
    // Integrated runs consume CT_POSTPROC.filtered_discovery automatically.
    pgls_caas_input        = pgls_caas_input        ?: ""

    // Tree parser mode used by Biopython.
    // Options: auto, newick, nexus
    pgls_tree_format       = pgls_tree_format       ?: "auto"

    // Alignment parser mode used by the site-level validator.
    // Options: auto, fasta, phylip, phylip-sequential, phylip-relaxed
    // "auto" picks FASTA for .fa/.fasta inputs and relaxed PHYLIP otherwise.
    pgls_alignment_format  = pgls_alignment_format  ?: "auto"

    // Keep CAAS rows whose reconstructed ancestral direction is ambiguous.
    pgls_keep_ambiguous    = pgls_keep_ambiguous    ?: true

    // Keep species whose observed amino acid is neither TOP nor BOTTOM.
    pgls_include_other     = pgls_include_other     ?: true

    // When the common discrete thresholds are interpreted as quantiles,
    // additionally require LOW species to fall below the median and HIGH
    // species to fall above the median.
    use_median_sep         = use_median_sep         ?: true

    // Number of worker threads used by the site-level GLS evaluation.
    pgls_threads           = pgls_threads           ?: 8

    // Benjamini-Hochberg FDR alpha applied to per-site PGLS p-values.
    pgls_site_fdr_alpha    = pgls_site_fdr_alpha    ?: 0.05

    // Minimum number of internal species observed in each amino-acid class
    // required before testing a site.
    pgls_min_per_class     = pgls_min_per_class     ?: 3

    // Trait-level phylogenetic model selection strategy.
    // Options:
    //   fixed -> always use pgls_phylo_model
    //   auto  -> compare pgls_phylo_candidates and choose best AICc model
    pgls_phylo_select      = pgls_phylo_select      ?: "auto"

    // Candidate phylogenetic models considered when pgls_phylo_select=auto.
    // Comma-separated values.
    // Options: bm, lambda, ou, eb, delta, kappa
    pgls_phylo_candidates  = pgls_phylo_candidates  ?: "bm, lambda, ou, eb, delta, kappa"

    // Bounds used when fitting phylogenetic parameters.
    // Options:
    //   wide    -> broad search ranges
    //   phylolm -> narrower phylolm-like ranges
    pgls_phylo_bounds      = pgls_phylo_bounds      ?: "phylolm"

    // Fixed phylogenetic covariance model used when pgls_phylo_select=fixed.
    // Options: bm, lambda, ou, eb, delta, kappa
    pgls_phylo_model       = pgls_phylo_model       ?: "lambda"

    // Optional fixed lambda value used when pgls_phylo_model=lambda.
    // Leave empty to let the runner fit lambda where applicable.
    pgls_lambda_value      = pgls_lambda_value      ?: ""

    // Fixed OU alpha used when pgls_phylo_model=ou.
    pgls_ou_alpha          = pgls_ou_alpha          ?: 0.0

    // Python-side logging verbosity.
    // Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
    pgls_log_level         = pgls_log_level         ?: "INFO"

    // Number of top site hits shown in the HTML report.
    pgls_top_hits_n        = pgls_top_hits_n        ?: 20

    // Number of top genes shown in the report gene summary.
    pgls_gene_top_n        = pgls_gene_top_n        ?: 20
}
