/*
 * RERconverge configuration
 */
params {
    // General options
    rer_tool                   = rer_tool                   ?: "" // Options: "build_trait", "build_trees", "build_matrix", "continuous"
    gene_trees                 = gene_trees                 ?: "$baseDir/Data/Gene_trees/geneTrees.txt" // Path to file with list of gene trees
    trait_out                  = trait_out                  ?: "$baseDir/Data/RER/RER_Traits/${params.traitname}.polished.output" // Path to output trait file from build_trait
    trees_out                  = trees_out                  ?: "$baseDir/Data/RER/RER_Objects/geneTrees.masterTree.pruned.output" // Path to output trees file from build_trees
    matrix_out                 = matrix_out                 ?: "${params.outdir}/RER_Objects/${params.traitname}.RERmatrix.output" // Path to output matrix file from build_matrix

    // Continuous analysis options
    rer_minsp                  = rer_minsp                  ?: "15" // Minimum number of species required per gene
    winsorizeRER               = winsorizeRER               ?: "3"  // Winsorization threshold for RER values
    winsorizeTrait             = winsorizeTrait             ?: "3"  // Winsorization threshold for trait values

    // ── Permutation statistics (Brownian Motion null phenotypes) ─────────────
    // Following Valenzuela et al. (2024): 10 batches x 100 permutations per trait.
    // Set rer_perm_batches = 0 to skip permutation testing entirely.
    rer_perm_batches           = rer_perm_batches           ?: 0    // Number of permutation batches (0 = skip)
    rer_perms_per_batch        = rer_perms_per_batch        ?: 100  // Permutations per batch
    rer_perm_mode              = rer_perm_mode              ?: "cc" // Permutation mode: "cc" (Complete Case)

    // ── Trait type routing ──────────────────────────────────────────────────
    // 'auto'       : auto-detect from value distribution (default; requires build_trait)
    // 'continuous' : force continuous analysis regardless of distribution
    // 'binary'     : force binary analysis regardless of distribution
    rer_trait_mode                = rer_trait_mode                ?: 'auto'

    // ── Binary-specific options ─────────────────────────────────────────────
    // rer_binary_clade: which branches in a foreground clade to mark foreground.
    //   'all'       – transition branch + all daughter branches (default)
    //   'ancestral' – only the inferred transition branch (convergence-focused)
    //   'terminal'  – only terminal branches leading to foreground species
    // rer_min_pos: minimum number of independent foreground lineages per gene (default 2).
    //   Genes with fewer foreground lineages are excluded from the analysis.
    rer_binary_clade              = rer_binary_clade              ?: 'all'
    rer_min_pos                   = rer_min_pos                   ?: 2

    // ── Gene-set mode ───────────────────────────────────────────────────────
    // 'all'      : run RER on every gene tree in the gene_trees file (default)
    // 'gene_set' : pre-filter the gene trees file to only genes from the
    //              postproc significant lists (top ∪ bottom)
    rer_gene_set_mode             = rer_gene_set_mode             ?: 'all'

    // Source files for gene_set mode.
    // Falls back to unified params.postproc_top/postproc_bottom if workflow-specific params not provided.
    rer_postproc_top              = rer_postproc_top              ?: params.postproc_top    ?: ""
    rer_postproc_bottom           = rer_postproc_bottom           ?: params.postproc_bottom ?: ""

    // ── Report thresholds ───────────────────────────────────────────────────
    rer_pval_threshold            = rer_pval_threshold            ?: 0.1  // BH p.adj significance cutoff
    rer_rho_threshold             = rer_rho_threshold             ?: 0.3   // minimum |Rho| for directional call
    rer_top_n_labels              = rer_top_n_labels              ?: 15    // genes labelled on correlation plot

    // ── Pathway enrichment ──────────────────────────────────────────────────
    // Provide a GMT file (e.g. MSigDB c2.all.vX.Y.symbols.gmt) to enable.
    // Leave empty to skip enrichment.
    rer_gmt_file                  = rer_gmt_file                  ?: ""   // path to GMT annotation file
    rer_enrich_min_genes          = rer_enrich_min_genes          ?: 10   // min genes per pathway
    rer_enrich_top_n              = rer_enrich_top_n              ?: 20   // top pathways to display
}

process {
    withName: 'RER_TRAIT' {
        publishDir = [
            path: { "${params.outdir}/RERConverge/RER_Traits/" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'RER_TREES' {
        publishDir = [
            path: { "${params.outdir}/RERConverge/RER_Objects" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'RER_MATRIX' {
        publishDir = [
            path: { "${params.outdir}/RERConverge/RER_Objects" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'RER_CONT' {
        publishDir = [
            path: { "${params.outdir}/RERConverge/RER_Results" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'RER_BIN' {
        publishDir = [
            path: { "${params.outdir}/RERConverge/RER_Results" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
