// CAAS Post-Processing Workflow Configuration
// Handles cluster filtering and characterization of CAAS discovery results

params {
    // Input/Output
    discovery_input = discovery_input ?: ""
    background_input = background_input ?: ""  // Required: path to background file(s) or directory (if not from CT_DISCOVERY)
    
    // Processing mode
    caas_postproc_mode = caas_postproc_mode ?: "exploratory"  // "exploratory" or "filter"
    
    // Exploratory mode parameters (parameter sweep)
    minlen_values = minlen_values ?: "2,3,4,10"
    maxcaas_values = maxcaas_values ?: "0.6,0.7,0.8"
    
    // Filter mode parameters (single run)
    filter_minlen = filter_minlen ?: 2
    filter_maxcaas = filter_maxcaas ?: 0.6
    
    // Gene-level filtering options
    gene_filter_mode = gene_filter_mode ?: "both"  // "none", "extreme", "dubious", "both"
    extreme_threshold = extreme_threshold ?: 0.99  // Top 1% = 0.99 quantile
    iqr_multiplier = iqr_multiplier ?: 3.0  // 3×IQR threshold for dubious genes
    
    // Visualization options
    generate_reports = generate_reports ?: true
    generate_manhattan = generate_manhattan ?: true
    manhattan_min_density = manhattan_min_density ?: 0.008  // Minimum density for Manhattan plot display
    
    // Processing options
    verbose = verbose ?: false
}

process {
    withName: 'CAAS_FILTER' {
        cpus = 1
        memory = { check_max( 500.MB, 'memory' ) }
        time = { check_max( 2.h, 'time' ) }
    }
    
    withName: 'CAAS_FILTER_SUMMARY' {
        cpus = 1
        memory = { check_max( 100.MB, 'memory' ) }
        time = { check_max( 10.m, 'time' ) }
    }
    
    withName: 'CAAS_POSTPROC_REPORT' {
        cpus = 2
        memory = { check_max( 4.GB, 'memory' ) }
        time = { check_max( 4.h, 'time' ) }
    }
}
