/*
 * FADE configuration
 * FUBAR Approach to Directional Evolution (HyPhy)
 * Tests per-site directional selection on foreground branches
 */
params {
    // ── Toggle ───────────────────────────────────────────────────────────────
    fade = fade ?: false

    // ── Shared alignment prep batching ───────────────────────────────────────
    // SELECTION_PREP runs PHYLIP→FASTA conversion and tree-filtering once for
    // both FADE and MOLERATE. selection_prep_batch_size > 1 groups N genes into
    // a single Nextflow task, drastically reducing SLURM scheduler overhead
    // compared to individual per-gene tasks.
    selection_prep_batch_size    = selection_prep_batch_size    ?: 500
    selection_prep_batch_workers = selection_prep_batch_workers ?: 10  // concurrent conversions per task

    // ── FADE-specific batching ───────────────────────────────────────────────
    // fade_batch_size > 1 groups N genes into a single Nextflow task, reducing
    // scheduler overhead on SLURM / Seqera. Default 1 = one task per gene.
    fade_batch_size    = fade_batch_size    ?: 200
    fade_batch_workers = fade_batch_workers ?: 8  // concurrent HyPhy calls per batch task

    // ── Run mode ─────────────────────────────────────────────────────────────
    // 'gene_set' : only genes from postproc/accumulation significant lists (via SELECTION_PREP)
    // 'all'      : every alignment file in params.alignment directory
    // Note: Actual gene-set inputs are auto-sourced by SELECTION_PREP from CT_POSTPROC
    // output when running integrated pipeline, or from params.sel_*_top/bottom when
    // running standalone selection workflows.
    fade_mode = fade_mode ?: 'gene_set'

    // ── Gene-set source files (gene_set mode only) ────────────────────────────────
    // Optional: provide user-defined gene lists for analysis (one gene per line, no header).
    // When not provided, FADE searches for postproc outputs from CT_POSTPROC
    // (integrated pipeline runs).
    // Note: Both TOP and BOTTOM sources should be provided when fade_mode = 'gene_set'.
    // Falls back to unified params.postproc_top/postproc_bottom if workflow-specific params not provided.
    fade_postproc_top        = fade_postproc_top        ?: params.postproc_top     ?: ""
    fade_postproc_bottom     = fade_postproc_bottom     ?: params.postproc_bottom  ?: ""

    // ── Protein alignment directory (defaults to params.alignment) ───────────
    // Override if protein alignments live in a different directory from the
    // codon alignments used by CT.
    fade_alignment = fade_alignment ?: ""

    // ── Statistical thresholds ───────────────────────────────────────────────
    // Bayes Factor threshold for calling a site under directional selection.
    // BF >= 100 is the conventional 'strong evidence' cutoff.
    fade_bf_threshold = fade_bf_threshold ?: 100

    // ── HyPhy FADE inference settings ────────────────────────────────────────
    // Substitution model for the background process (protein).
    // LG is used for consistency with the ASR step in CT_DISAMBIGUATION.
    // Options: JTT, WAG, LG, Blosum62, mtMet, mtVer, mtInv, gcpREV, HIVBm, HIVWm, GTR
    fade_model  = fade_model  ?: 'LG'

    // Path to the LG substitution matrix dat file.
    // Staged into every FADE_RUN working directory so HyPhy can load it.
    // Defaults to the copy bundled in this repo (subworkflows/SELECTION/local/dat/lg.dat).
    lg_dat_path = lg_dat_path ?: "${projectDir}/subworkflows/SELECTION/local/dat/lg.dat"

    // Inference method
    // Options: Variational-Bayes (fastest), Collapsed-Gibbs, Metropolis-Hastings
    fade_method = fade_method ?: 'Variational-Bayes'

    // Grid resolution for posterior estimation (Variational-Bayes or MCMC)
    fade_grid   = fade_grid   ?: 20

    // MCMC settings (only used when fade_method != 'Variational-Bayes')
    fade_chains       = fade_chains       ?: 5
    fade_chain_length = fade_chain_length ?: 2000000
    fade_burn_in      = fade_burn_in      ?: 1000000
    fade_samples      = fade_samples      ?: 1000

    // Dirichlet concentration prior
    fade_concentration = fade_concentration ?: 0.5

    // ── Report options ───────────────────────────────────────────────────────
    // Minimum number of genes with >= 1 significant site required to render
    // the detailed heatmaps and phylotree sections.
    fade_min_genes_for_heatmap = fade_min_genes_for_heatmap ?: 1

    // Path to hyphy-analyses directory (contains molerate.bf, etc.)
    // Defaults to /hyphy-analyses inside the container.
    hyphy_analyses_path = hyphy_analyses_path ?: '/hyphy-analyses'
}

// Resource configuration for FADE processes is in conf/resources.config
