/*
 * CT Signification Analysis Configuration
 * Runs upstream of disambiguation; requires bootstrap output from CT RESAMPLE / BOOTSTRAP.
 */

params {
    // Bootstrap input (required)
    bootstrap_input = bootstrap_input ?: ""       // Path to directory containing .boot files from permutation tests

    // Significance thresholds
    alpha_threshold = alpha_threshold ?: 0.1       // Alpha level for both hypergeometric and permutation tests

    // Output options
    export_gene_lists = export_gene_lists ?: true   // Export gene lists for enrichment analysis
    export_meta_ct    = export_meta_ct    ?: true   // Export meta-CT metadata

    // Gene list export formats
    gene_list_format = gene_list_format ?: "txt"    // Format: txt (one gene per line)
}
