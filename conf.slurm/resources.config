#!/usr/bin/env nextflow

/*
 * Resource configuration: defaults + process label requirements
 */

params {
    // Defaults used when no profile overrides are active
    max_memory = 64.GB
    max_cpus   = 64
    max_time   = 5.day
}

process {
    // ── Generic labels ─────────────────────────────────────────────────────
    withLabel:process_discovery {
        cpus   = { check_max( 8,         'cpus'    ) }
        memory = { check_max( 2.GB,    'memory'  ) }
        time   = { check_max( 1.h,       'time'    ) }
        maxForks   = 8 // Number of parallel jobs to run. Should be total assigned cores % cores per job
    }
    withLabel:process_resample {
        cpus   = { check_max( 12, 'cpus'    ) }
        memory = { check_max( 4.GB, 'memory'  ) }
        time   = { check_max( 2.h, 'time'    ) }
    }
    withLabel:process_boot {
        cpus   = { check_max( 8, 'cpus'    ) }
        memory = { check_max( 16.GB, 'memory'  ) }
        time   = { check_max( 72.h, 'time'    ) }
        maxForks   = 8 // Number of parallel jobs to run. Should be total assigned cores % cores per job
    }
    withLabel:process_low {
        cpus   = { check_max( 1,      'cpus'   ) }
        memory = { check_max( 500.MB, 'memory' ) }
        time   = { check_max( 2.h,    'time'   ) }
    }
    withLabel:process_medium {
        cpus   = { check_max( 2,   'cpus'   ) }
        memory = { check_max( 4.GB, 'memory' ) }
        time   = { check_max( 4.h,  'time'   ) }
    }
    withLabel:process_long_compute {
        cpus   = { check_max( 1,    'cpus'   ) }
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 12.h * task.attempt, 'time'   ) }
    }
    withLabel:process_reporting {
        cpus   = { check_max( 4,   'cpus'   ) }
        memory = { check_max( 2.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h  * task.attempt, 'time'   ) }
    }
    withLabel:process_reporting_phenotype {
        cpus   = { check_max( 10,   'cpus'   ) }
        memory = { check_max( 6.GB * task.attempt, 'memory' ) }
        time   = { check_max( 2.h  * task.attempt, 'time'   ) }
    }
    withLabel:process_reporting_dataset {
        cpus   = { check_max( 4,   'cpus'   ) }
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 2.h  * task.attempt, 'time'   ) }
    }
    withLabel:process_contrast_selection {
        cpus   = { check_max( 8,   'cpus'   ) }
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h  * task.attempt, 'time'   ) }
    }
    withLabel:error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }

    withName: 'DISCOVERY_BATCHED' {
        cpus   = { check_max( params.ct_discovery_batch_workers as int, 'cpus' ) }
        memory = { check_max( 100.MB, 'memory' ) }
        time   = { check_max( 1.h, 'time' ) }
    }

    withName: 'BOOTSTRAP_BATCHED' {
        cpus   = { check_max( 2 * (params.ct_bootstrap_batch_workers as int), 'cpus' ) }
        memory = { check_max( 2.GB, 'memory' ) }
        time   = { check_max( 72.h, 'time' ) }
    }

    // ── CT Post-Processing ────────────────────────────────────────────────
    withName: 'CT_FILTER' {
        cpus   = { check_max( 2,      'cpus'   ) }
        memory = { check_max( 1.GB, 'memory' ) }
        time   = { check_max( 2.h,    'time'   ) }
    }
    withName: 'CT_FILTER_SUMMARY' {
        cpus   = { check_max( 2,      'cpus'   ) }
        memory = { check_max( 1.GB, 'memory' ) }
        time   = { check_max( 10.m,   'time'   ) }
    }
    withName: 'CT_POSTPROC_REPORT' {
        cpus   = { check_max( 12,    'cpus'   ) }
        memory = { check_max( 6.GB, 'memory' ) }
        time   = { check_max( 4.h,  'time'   ) }
    }

    // ── CT Signification ──────────────────────────────────────────────────
    withName: 'CAAS_SIGNIFICATION_REPORT' {
        cpus   = { check_max( 12,    'cpus'   ) }
        memory = { check_max( 4.GB, 'memory' ) }
        time   = { check_max( 2.h,  'time'   ) }
    }

    // ── CT Accumulation ───────────────────────────────────────────────────
    withName: 'CT_ACCUMULATION_AGGREGATE' {
        cpus   = { check_max( 16,    'cpus'   ) }
        memory = { check_max( 8.GB  * task.attempt, 'memory' ) }
        time   = { check_max( 4.h   * task.attempt, 'time'   ) }
    }
    withName: 'CT_ACCUMULATION_RANDOMIZE' {
        cpus   = { check_max( 12,    'cpus'   ) }
        memory = { check_max( 24.GB * task.attempt, 'memory' ) }
        time   = { check_max( 12.h  * task.attempt, 'time'   ) }
    }

    // ── ORA / STRING ──────────────────────────────────────────────────────
    withName: 'ORA_GENERAL_REPORT' {
        cpus   = { check_max( 8,    'cpus'   ) }
        memory = { check_max( 8.GB, 'memory' ) }
        time   = { check_max( 6.h,  'time'   ) }
    }
    withName: 'STRING_GENERAL_REPORT' {
        cpus   = { check_max( 8,    'cpus'   ) }
        memory = { check_max( 8.GB, 'memory' ) }
        time   = { check_max( 6.h,  'time'   ) }
    }

    // ── FADE ──────────────────────────────────────────────────────────────
    withName: 'PHYLIP_TO_FASTA' {
        cpus   = { check_max( 1,    'cpus'   ) }
        memory = { check_max( 2.GB * task.attempt, 'memory' ) }
        time   = { check_max( 30.m * task.attempt, 'time'   ) }
    }
    withName: 'ANNOTATE_TREE_FG' {
        cpus   = { check_max( 8,    'cpus'   ) }
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 30.m * task.attempt, 'time'   ) }
    }
    withName: 'COLLECT_GENE_SETS' {
        cpus   = { check_max( 2,    'cpus'   ) }
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 30.m * task.attempt, 'time'   ) }
    }
    withName: 'FADE_RUN' {
        cpus   = { check_max( 12,    'cpus'   ) }
        memory = { check_max( 4.GB  * task.attempt, 'memory' ) }
        time   = { check_max( 12.h  * task.attempt, 'time'   ) }
    }
    withName: 'FADE_REPORT' {
        cpus   = { check_max( 8,    'cpus'   ) }
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h  * task.attempt, 'time'   ) }
    }

    // ── MoleRate ──────────────────────────────────────────────────────────
    withName: 'EXTRACT_FG_BRANCHES' {
        cpus   = { check_max( 8,    'cpus'   ) }
        memory = { check_max( 1.GB * task.attempt, 'memory' ) }
        time   = { check_max( 30.m * task.attempt, 'time'   ) }
    }
    withName: 'MOLERATE_RUN' {
        cpus   = { check_max( 12,    'cpus'   ) }
        memory = { check_max( 4.GB  * task.attempt, 'memory' ) }
        time   = { check_max( 12.h  * task.attempt, 'time'   ) }
    }
    withName: 'MOLERATE_REPORT' {
        cpus   = { check_max( 8,    'cpus'   ) }
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h  * task.attempt, 'time'   ) }
    }

    // ── VEP characterization ────────────────────────────────────────────────
    withLabel: 'process_vep' {
        cpus   = { check_max( 4,                      'cpus'   ) }
        memory = { check_max( 8.GB * task.attempt,    'memory' ) }
        time   = { check_max( 4.h  * task.attempt,    'time'   ) }
    }
    withName: 'PROT2COORD' {
        cpus   = { check_max( 4,                      'cpus'   ) }
        memory = { check_max( 8.GB * task.attempt,    'memory' ) }
        time   = { check_max( 8.h  * task.attempt,    'time'   ) }
    }
    withName: 'PROT2AA' {
        cpus   = { check_max( 4,                      'cpus'   ) }
        memory = { check_max( 8.GB * task.attempt,    'memory' ) }
        time   = { check_max( 8.h  * task.attempt,    'time'   ) }
    }
    withName: 'PRIMATEAI_MAP' {
        // Streams the full PrimateAI-3D database (~2 GB gz); needs enough memory
        // to hold the in-memory position lookup table.
        cpus   = { check_max( 2,                      'cpus'   ) }
        memory = { check_max( 16.GB * task.attempt,   'memory' ) }
        time   = { check_max( 8.h  * task.attempt,    'time'   ) }
    }

    // ── Scoring ─────────────────────────────────────────────────────────────
    withName: 'SCORING_COMPUTE' {
        cpus   = { check_max( 4,    'cpus'   ) }
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h  * task.attempt, 'time'   ) }
    }
    withName: 'SCORING_REPORT' {
        cpus   = { check_max( 8,    'cpus'   ) }
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h  * task.attempt, 'time'   ) }
    }
}
