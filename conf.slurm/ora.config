/*
 * ORA configuration
 */
params {
    // Enable ORA module
    ora = ora ?: false

    // Inputs for standalone ORA mode (optional when piping from CT postproc)
    ora_background_input = ora_background_input ?: ""
    ora_gene_lists_input = ora_gene_lists_input ?: ""
    accumulation_ora_gene_lists_input = accumulation_ora_gene_lists_input ?: ""

    // Core WebGestalt ORA settings
    ora_project_name = ora_project_name ?: "ORA_WebGestalt"
    ora_accumulation_project_name = ora_accumulation_project_name ?: "ORA_Accumulation"
    ora_organism = ora_organism ?: "hsapiens"
    ora_databases_default = ora_databases_default ?: "geneontology_Biological_Process_noRedundant,geneontology_Cellular_Component_noRedundant,geneontology_Molecular_Function_noRedundant,pathway_KEGG,pathway_Reactome,pathway_WikiPathways,pathway_WikiPathways_cancer,disease_Disgenet,disease_OMIM,phenotype_Human_Phenotype_Ontology,network_CORUMA,network_Kinase_target"
    ora_databases_extra = ora_databases_extra ?: "pathway_Panther,pathway_WP_Pathway_Figure_OCR,pathway_mitocarta,network_PPI_BIOGRID,network_Transcription_Factor_target,network_miRNA_target,chromosomalLocation_CytogeneticBand"

    // Statistical thresholds
    ora_min_num = ora_min_num ?: 5
    ora_max_num = ora_max_num ?: 500
    ora_fdr = ora_fdr ?: 0.1
    ora_top_thr = ora_top_thr ?: 15
    ora_report_num = ora_report_num ?: 15
    ora_threads = ora_threads ?: 8

    // Comparative visualization and characterization controls
    ora_enable_spider_plot = ora_enable_spider_plot ?: true
    ora_enable_overlap_heatmap = ora_enable_overlap_heatmap ?: true
    ora_enable_enrichment_map = ora_enable_enrichment_map ?: true
    ora_overlap_top_terms = ora_overlap_top_terms ?: 50
    ora_compare_metric = ora_compare_metric ?: 'overlap'

    // ── STRING (rbioapi) enrichment ──────────────────────────────────────────
    // Enable STRING enrichment (runs in parallel with WebGestaltR ORA when --ora is set)
    string = string ?: true

    string_project_name  = string_project_name  ?: 'STRING_Analysis'
    string_accumulation_project_name = string_accumulation_project_name ?: 'STRING_Accumulation'

    // NCBI taxon ID for the species of interest (default: 9606 = Homo sapiens)
    string_species       = string_species ?: 9606

    // Minimum combined interaction score to consider (0–1000; 400 = medium confidence)
    string_required_score = string_required_score ?: 400

    // Statistical thresholds (mirroring ora_fdr / ora_top_thr)
    string_fdr           = string_fdr        ?: 0.9
    string_top_thr       = string_top_thr    ?: 15
    string_report_num    = string_report_num ?: 20

    // PPI density enrichment test (rba_string_enrichment_ppi)
    string_enable_ppi    = string_enable_ppi ?: false

    // Visualization toggles (same semantics as the ora_enable_* params)
    string_enable_spider_plot     = string_enable_spider_plot     ?: true
    string_enable_overlap_heatmap = string_enable_overlap_heatmap ?: true
    string_enable_enrichment_map  = string_enable_enrichment_map  ?: true
    string_overlap_top_terms      = string_overlap_top_terms      ?: 50
    string_compare_metric         = string_compare_metric         ?: 'overlap'
}

// Resource configuration for ORA/STRING processes is in conf/resources.config
