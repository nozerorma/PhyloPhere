/*
 * Reporting tool configuration (trait analysis reports)
 */
 
cleanup = false // Cleanup work directory after execution. Toggle at your own guise. Setting to false can be useful for debugging, but will consume more disk space.

params {
    // Main parameters
    help               = help               ?: false // Show help and exit
    outdir             = outdir             ?: "$baseDir/Out" // Output directory
    workDir            = workDir            ?: "$baseDir/Out/work" // Working directory
    
    // Data input parameters
    my_traits          = my_traits          ?: "" // Path to traits CSV file
    tree               = tree               ?: "" // Path to species tree file (newick)
    traitname          = traitname          ?: "" // Name of the trait column to analyze
    tax_id             = tax_id             ?: "/data/samanthafs/scratch/lab_anavarro/mramon/2.Primates/1.Primates_data/5.Phylogeny/taxid_species_family.tsv" // Path to taxonomic ID mapping file (taxid to species)
    gene_ensembl_file   = gene_ensembl_file ?: "/data/samanthafs/scratch/lab_anavarro/mramon/2.Primates/1.Primates_data/2.Alignments/ensembl_genes.output" // Path to gene Ensembl mapping file (gene ID to gene name)

    // Reporting parameters
    reporting          = reporting          ?: false // Whether to generate HTML reports using Rmarkdown. Implicit if prune_data is true.
    sp_colname         = sp_colname         ?: "species" // Name of the species column in the traits CSV file
    clade_name         = clade_name         ?: "primates" // Name of the clade to focus on in the report
    taxon_of_interest  = taxon_of_interest  ?: "family" // Taxonomic level of interest (e.g., "family", "order")
    seed               = seed               ?: "1998" // Random seed for reproducibility
 
    // Using population data parameters?
    // Specify that these traits would work for frequency data (e.g., prevalence, incidence)
    // rethink the naming convention here...
    // maybe could also be applied for median values with sample sizes?
    // maybe p_trait could be n_trait, and n_trait could be c_trait?
    n_trait            = n_trait            ?: "" // Trait with number of individuals sampled (population size)
    c_trait            = c_trait            ?: "" // Trait with number of observed cases (e.g., number of neoplasia cases)
   
    // Interested in other phenotypes?
    secondary_trait    = secondary_trait    ?: "" // Name of a secondary trait column to include (optional)
    branch_trait       = branch_trait       ?: "" // Name of the trait column to use for branch coloring (optional)

    // ____________________________________

    // Contrast selection parameters
    contrast_selection = contrast_selection ?: false // Whether to run the contrast selection workflow

    // Discrete categorization method (used when n_trait/c_trait columns are absent from the trait file)
    // Options: quartile, quintile, decile, median_sd, parameterized
    discrete_method    = discrete_method    ?: "decile"
    top_quantile       = top_quantile       ?: "0.90"   // upper threshold for 'parameterized' method
    bottom_quantile    = bottom_quantile    ?: "0.10"   // lower threshold for 'parameterized' method
    contrast_max_iter  = contrast_max_iter  ?: "3"      // maximum iterations for the contrast selection algorithm (3 for 4 contrasts, 4 for 5 contrasts, etc.)
    min_contrasts      = min_contrasts      ?: 3    // Minimum number of foreground contrasts (fg pairs) required in the caastools traitfile to proceed with the CT pipeline; runs with fewer pairs are skipped gracefully 

    // ____________________________________

    // Data pruning parameters
    // This is to be run with --reporting. Recommended use case: run once WITH --reporting only, and another with both ---reporting and --prune_data
    prune_data         = prune_data         ?: "" // Path to the species pruning list
    prune_list_secondary = prune_list_secondary ?: "" // Optional secondary prune list (e.g., for a secondary trait)

    // ____________________________________

    // General CT switches
    // Execution order in integrated runs: signification -> disambiguation -> post-processing
    ct_signification = ct_signification ?: false // Whether to run CT signification workflow (upstream of disambiguation; requires bootstrap input)
    ct_disambiguation = ct_disambiguation ?: false // Whether to run CT disambiguation workflow (downstream of signification; requires signification output)
    ct_postproc      = ct_postproc      ?: false // Whether to run CT post-processing workflow (downstream of disambiguation)
    ct_accumulation  = ct_accumulation  ?: false // Whether to run CT accumulation workflow (downstream of post-processing; requires post-processing output)


}

// Capture exit codes from upstream processes when piping
// Different reports and logs to capture execution details.
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
}
trace {
    enabled = true
    trace.overwrite = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag.html"
}
tower {
    accessToken = "eyJ0aWQiOiAxMTg2MX0uYmFkMTY1ZDk0MGQxZmU0MTRjOWIyYTdmOThkMjdmZDU0OTQ1OTAzZA==" // Replace with your actual Tower access token if you want to use Nextflow Tower for monitoring
    enabled = false // Set to true to enable Nextflow Tower monitoring
}
