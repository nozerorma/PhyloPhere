/*
 * MoleRate configuration
 * Relative Evolutionary Molecular Rate (HyPhy / hyphy-analyses)
 * Tests whether foreground branches have accelerated or decelerated
 * evolutionary rates relative to background branches.
 */
params {
    // ── Toggle ───────────────────────────────────────────────────────────────
    molerate = molerate ?: false

    // ── Batching ─────────────────────────────────────────────────────────────
    // molerate_batch_size > 1 groups N genes into a single Nextflow task,
    // reducing scheduler overhead on SLURM / Seqera. Default 1 = one task per gene.
    molerate_batch_size    = molerate_batch_size    ?: 200
    molerate_batch_workers = molerate_batch_workers ?: 10  // concurrent HyPhy calls per batch task

    // MoleRate always runs over all preprocessed genes.

    // ── Protein alignment directory (defaults to params.alignment) ───────────
    molerate_alignment = molerate_alignment ?: ""

    // ── HyPhy MoleRate inference settings ────────────────────────────────────
    // Substitution model (protein alignments).
    // LG is used for consistency with the ASR step in CT_DISAMBIGUATION.
    // Options: LG, WAG, JTT, JC69, mtMet, mtVer, mtInv, gcpREV, HIVBm, HIVWm, GTR
    molerate_model = molerate_model ?: 'LG'

    // Path to the LG dat file (shared with FADE via lg_dat_path declared in fade.config).
    // Only declare here when running MoleRate WITHOUT FADE (avoids double-declaration).
    // lg_dat_path = lg_dat_path ?: "${projectDir}/subworkflows/SELECTION/local/dat/lg.dat"

    // Site-to-site rate variation: None, Gamma, GDD
    molerate_rv = molerate_rv ?: 'None'

    // Number of rate classes for Gamma/GDD models
    molerate_rate_classes = molerate_rate_classes ?: 4

    // Internal-branch labelling strategy
    // Options: none, all-descendants, some-descendants, parsimony
    molerate_labeling_strategy = molerate_labeling_strategy ?: 'all-descendants'

    // Whether to run per-branch LRT tests (2xT additional fits)
    molerate_branch_tests = molerate_branch_tests ?: true

    // Skip the fully unconstrained model fit (faster when true)
    molerate_skip_full_model = molerate_skip_full_model ?: false

    // ── Statistical thresholds (report) ─────────────────────────────────────
    // Holm-Bonferroni corrected p-value threshold for accelerated/decelerated calls
    molerate_pval_threshold = molerate_pval_threshold ?: 0.05

    // Minimum |log2(R_test / R_background)| to highlight on volcano plot
    molerate_log2fc_threshold = molerate_log2fc_threshold ?: 0.5

    // ── Report options ───────────────────────────────────────────────────────
    // Top-N genes to label on the volcano plot
    molerate_top_n_labels = molerate_top_n_labels ?: 15

    // Path to hyphy-analyses directory (shared with FADE)
    // hyphy_analyses_path is already declared in fade.config; only set here
    // if FADE is NOT enabled.
    // hyphy_analyses_path = hyphy_analyses_path ?: '/hyphy-analyses'
}

// Resource configuration for MoleRate processes is in conf/resources.config
