/*
 * VEP characterization configuration
 * ────────────────────────────────────
 * Annotates CAAS positions with:
 *   prot2coord  – genomic coordinates of each CAAS site
 *   prot2aa     – protein-position query strings for TransVar (GENE:p.N)
 *   transvar    – canonical transcript and hg38 variant annotation via TransVar
 *   primateai   – PrimateAI-3D pathogenicity scores for the CAAS amino-acid changes
 *
 * Runs at the characterization level, consuming CT_POSTPROC.filtered_discovery.
 * Does not feed into SCORING.
 */

params {
    // Enable the VEP characterization workflow.
    vep                = vep                ?: false

    // Standalone CAAS input file.
    // Integrated runs consume CT_POSTPROC.filtered_discovery automatically.
    vep_caas_input     = vep_caas_input     ?: ""

    // Optional precomputed stage inputs.
    // When provided, VEP skips the corresponding stage and consumes these files.
    vep_aa2nuc_input   = vep_aa2nuc_input   ?: ""   // aa2nuc_global.csv
    vep_aa2prot_input  = vep_aa2prot_input  ?: ""   // aa2prot_global.csv

    // ── Per-project directories (REQUIRED when vep = true) ───────────────
    // vep_cds_dir:
    //   Directory containing per-gene CDS nucleotide alignments in FASTA format,
    //   or a .tar.gz archive of the same files (members extracted on-demand per gene).
    //   File naming convention: GENE.Homo*.fasta  (e.g. A1BG.Homo_sapiens.fasta)
    vep_cds_dir        = vep_cds_dir        ?: ""

    // vep_track_dir:
    //   Directory containing per-gene codon-filtering tracking HTML files produced
    //   by the upstream codon-filter step, or a .tar.gz archive of the same files
    //   (members extracted on-demand per gene).
    //   File naming convention: GENE.html or GENE.*.html
    vep_track_dir      = vep_track_dir      ?: ""

    // ── Static reference data ─────────────────────────────────────────────
    // Defaults point to the dat/ directory bundled with the VEP subworkflow.
    // Override any path to use files stored elsewhere (e.g. a shared reference store).

    // Homo sapiens CDS reference FASTA (gzip-compressed).
    vep_hs_cds         = vep_hs_cds         ?: "${projectDir}/subworkflows/VEP/dat/Homo_sapiens.cds.fa.gz"

    // GFF genome annotation sorted by transcript / protein ID.
    vep_gff            = vep_gff            ?: "${projectDir}/subworkflows/VEP/dat/Homo_sapiens.sorted.gff"

    // Two-column TSV mapping gene symbols to Ensembl protein IDs.
    vep_gene_equiv     = vep_gene_equiv     ?: "${projectDir}/subworkflows/VEP/dat/proteiID_gene_equivalences.txt"

    // TransVar index directory containing hg38 annotation databases.
    // Build with: transvar config --download_anno --refversion hg38
    vep_transvar_db    = vep_transvar_db    ?: "${projectDir}/subworkflows/VEP/dat/transvar"

    // Optional explicit TransVar executable path. Falls back to PATH when unset.
    vep_transvar_bin   = vep_transvar_bin   ?: "/homes/users/mramon/.conda/envs/transvar/bin/transvar"

    // Optional TransVar configuration file. Set when the binary lives in a
    // different environment than the workflow runtime.
    vep_transvar_cfg   = vep_transvar_cfg   ?: "${projectDir}/subworkflows/VEP/dat/transvar/transvar.cfg"

    // Optional explicit reference FASTA for TransVar panno.
    // Useful when 'transvar config --refversion' cannot resolve Reference.
    vep_transvar_reference = vep_transvar_reference ?: "${projectDir}/subworkflows/VEP/dat/transvar/hg38.fa"

    // PrimateAI-3D pathogenicity database (hg38, gzip-compressed).
    vep_primateai_db   = vep_primateai_db   ?: "${projectDir}/subworkflows/VEP/dat/PrimateAI-3D.hg38.txt.gz"

    // Reference genome version passed to TransVar via --refversion.
    vep_refversion     = vep_refversion     ?: "hg38"
}
