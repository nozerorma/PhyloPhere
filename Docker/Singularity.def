Bootstrap: docker
From: mambaorg/micromamba:1.5.1

%labels
    image.author.name Miguel Ramon
    image.author.email miguel.ramon@upf.edu

%files
    phylophere /phylophere

%post
    set -euo pipefail

    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -qq -y --no-install-recommends \
        software-properties-common \
        dirmngr \
        ed \
        gpg-agent \
        less \
        locales \
        ca-certificates \
        procps \
        git
    rm -rf /var/lib/apt/lists/*

    chmod +x /phylophere/environment/install_env.sh
    /phylophere/environment/install_env.sh /phylophere/environment/phylophere.yml

    chmod +x /phylophere/subworkflows/CT/local/ct

    git clone --depth 1 --branch master \
        https://github.com/veg/hyphy-analyses.git /hyphy-analyses
    chmod -R a+rX /hyphy-analyses

%environment
    export PATH=/phylophere:$PATH
    export PATH=/opt/conda/envs/phylophere/bin:$PATH

%runscript
    cd /phylophere
    exec /usr/local/bin/_entrypoint.sh "$@"

%startscript
    cd /phylophere
    exec /usr/local/bin/_entrypoint.sh "$@"
